# yc-plugin / youtube-upload settings
#
# This file is a TEMPLATE. Copy it to ~/.claude/plugins/data/yc-plugin/.env
# and fill in your own values. Never commit the real .env to a public repo.

# ---------------------------------------------------------------
# REQUIRED: path to your OAuth client_secret JSON
# ---------------------------------------------------------------
# How to get one (one-time, ~3 minutes):
#   1. Open https://console.cloud.google.com/
#   2. Create a project (any name)
#   3. APIs & Services → Library → search "YouTube Data API v3" → Enable
#   4. APIs & Services → OAuth consent screen → External → fill basics → save
#      Add yourself as a Test user (skip Google verification — for personal use)
#   5. APIs & Services → Credentials → Create Credentials → OAuth client ID
#      → Application type: Desktop app → name it anything → Create
#   6. Download the JSON. Save it somewhere safe.
#   7. Paste the absolute path below.
YOUTUBE_CLIENT_SECRET_PATH=

# ---------------------------------------------------------------
# Default upload settings (override per-call with CLI flags)
# ---------------------------------------------------------------
# Privacy when not specified: public | unlisted | private
YOUTUBE_DEFAULT_PRIVACY=unlisted

# Category id (22 = People & Blogs, 24 = Entertainment, 27 = Education,
# 10 = Music, 23 = Comedy, 26 = Howto & Style)
YOUTUBE_DEFAULT_CATEGORY=22

# Default tags, comma-separated. Used when --tags not supplied.
YOUTUBE_DEFAULT_TAGS=

# Optional: human label for your channel (only shown in log messages)
YOUTUBE_CHANNEL_NAME=
